  "require": {
    "php": "^8.0",
    "vlucas/phpdotenv": "^5.4",
    "ext-ldap": "*",
    "ext-json": "*",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.0",
