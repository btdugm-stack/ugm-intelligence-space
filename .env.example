# Application Environment
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/ugm-intelligence-space-poc

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ugm_intelligence
DB_USERNAME=root
DB_PASSWORD=
DB_ENABLE=false

# LDAP Configuration (for SSO)
LDAP_ENABLED=false
LDAP_SERVER=ldap.ugm.ac.id
LDAP_PORT=389
LDAP_BASE_DN=dc=ugm,dc=ac,dc=id
LDAP_BIND_USER=
LDAP_BIND_PASSWORD=

# Session Configuration
SESSION_TIMEOUT=1800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true

# Encryption
ENCRYPTION_KEY=

# Security
CSRF_TOKEN_LENGTH=32

# Logging
LOG_LEVEL=debug
LOG_PATH=logs

# Cache (Redis)
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Email (for notifications)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ugm-intelligence.ac.id

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW=300
